{
  "ci": {
    "collect": {
      "startServerCommand": "npm run preview -- --host 127.0.0.1 --port 4175",
      "startServerReadyPattern": "Local:",
      "url": [
        "http://127.0.0.1:4175/CentraldeFilamentos/",
        "http://127.0.0.1:4175/CentraldeFilamentos/color-picker.html",
        "http://127.0.0.1:4175/CentraldeFilamentos/estadisticas.html"
      ],
      "numberOfRuns": 3,
      "settings": {
        "chromeFlags": "--headless --no-sandbox --disable-gpu"
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.9 }],
        "categories:performance": ["warn", { "minScore": 0.7 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 4000 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 600 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 2500 }],
        "total-byte-weight": ["warn", { "maxNumericValue": 2000000 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci/reports"
    }
  }
}
